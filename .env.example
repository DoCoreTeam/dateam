NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# autolink 사전계산 큐 워커 인증 시크릿.
# pg_cron + pg_net 이 POST /api/work/autolink/worker 호출 시 Authorization: Bearer <값> 로 검증.
# 충분히 긴 무작위 문자열로 설정(예: openssl rand -hex 32). 하드코딩 금지.
AUTOLINK_CRON_SECRET=your-random-worker-secret
